---
import interWoff2 from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import newsreaderWoff2 from "@fontsource-variable/newsreader/files/newsreader-latin-wght-normal.woff2?url";
import siteConfig from "../data/site-config";
import "../styles/global.css";

export type Props = {
	title?: string;
	description?: string;
	image?: { src: string; alt?: string };
	pageType?: "website" | "article";
	keywords?: string[];
	noIndex?: boolean;
};

const {
	description = "",
	image = siteConfig.image,
	pageType = "website",
	keywords = [],
	noIndex = false,
} = Astro.props;

const title = [Astro.props.title, siteConfig.title].filter(Boolean).join(" | ");
const resolvedImage = image?.src
	? {
			src: new URL(image.src, Astro.site).toString(),
			alt: image.alt,
		}
	: undefined;
const canonicalURL = new URL(Astro.request.url, Astro.site);

// Career-focused default keywords
const defaultKeywords = [
	"Bartłomiej Miłosz",
	"architect to data analytics",
	"career transition Warsaw",
	"PJATK computer science",
	"client consulting experience",
	"interior architect Poland",
	"data analyst portfolio",
];

const allKeywords = [...defaultKeywords, ...keywords].join(", ");

/**
 * Proper canonical URL formatting
 */
function formatCanonicalURL(url: string | URL) {
	let path = url.toString();
	const hasQueryParams = path.includes("?");
	// Remove trailing slash if query params exist, add if not
	return path.replace(/\/?$/, hasQueryParams ? "" : "/");
}

// Structured data for personal branding & career transition
const structuredData = {
	"@context": "https://schema.org",
	"@type": "Person",
	name: "Bartłomiej Miłosz",
	jobTitle: "Interior Architect transitioning to Data Analytics",
	description:
		description ||
		"Interior architect with 4+ years client consulting experience, transitioning to data analytics. Currently studying Computer Science at PJATK Warsaw.",
	url: canonicalURL.toString(),
	worksFor: {
		"@type": "Organization",
		name: "",
	},
	alumniOf: [
		{
			"@type": "EducationalOrganization",
			name: "PJATK Warsaw",
			description: "Computer Science studies",
		},
		{
			"@type": "EducationalOrganization",
			name: "Rzeszów University of Technology",
			description: "Master of Architecture",
		},
	],
	knowsAbout: [
		"Interior Architecture",
		"Project Management",
		"Client Consulting",
		"Data Analytics",
		"Python Programming",
		"Business Analysis",
	],
	sameAs: [
		"https://linkedin.com/in/bartlomiej-milosz",
		"https://github.com/bartlomiejMilosz",
	],
	address: {
		"@type": "PostalAddress",
		addressLocality: "Warsaw",
		addressCountry: "Poland",
	},
};
---

<!-- High Priority Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<title>{title}</title>
<meta name="generator" content={Astro.generator} />

<!-- SEO & Personal Branding -->
<meta name="description" content={description} />
<meta name="keywords" content={allKeywords} />
<meta name="author" content="Bartłomiej Miłosz" />
<meta name="google-site-verification" content="J7TZMTAzkpS-OZVZkn5-QmHWtmekk5EMFCerf3LsBtE" />
<meta name="robots" content={noIndex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large, max-snippet:-1'} />

<!-- Geographic & Career Context -->
<meta name="geo.region" content="PL-MZ" />
<meta name="geo.placename" content="Warsaw, Poland" />
<meta name="DC.title" content={title} />
<meta name="DC.creator" content="Bartłomiej Miłosz" />
<meta name="DC.subject" content="Career Transition, Data Analytics, Architecture" />
<meta name="DC.language" content="en" />

<!-- Performance & Resource Hints -->
<link rel="dns-prefetch" href="//fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

<!-- Fonts with optimized loading -->
<link rel="preload" as="font" type="font/woff2" href={interWoff2} crossorigin="anonymous" />
<link rel="preload" as="font" type="font/woff2" href={newsreaderWoff2} crossorigin="anonymous" />

<!-- Favicons & App Icons -->
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="theme-color" content="#1a1a1a" />
<meta name="msapplication-TileColor" content="#1a1a1a" />

<!-- Technical SEO -->
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="alternate" type="application/rss+xml" href="/rss.xml" title="RSS Feed - Bartłomiej Miłosz" />
<link rel="canonical" href={formatCanonicalURL(canonicalURL)} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={pageType} />
<meta property="og:url" content={formatCanonicalURL(canonicalURL)} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:site_name" content="Bartłomiej Miłosz - Architect to Analytics Portfolio" />
<meta property="og:locale" content="en_US" />
{resolvedImage?.src && <meta property="og:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta property="og:image:alt" content={resolvedImage.alt} />}
{resolvedImage?.src && <meta property="og:image:width" content="1200" />}
{resolvedImage?.src && <meta property="og:image:height" content="630" />}

<!-- Enhanced Twitter Cards -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={formatCanonicalURL(canonicalURL)} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:creator" content="@your_twitter_handle" />
<meta name="twitter:site" content="@your_twitter_handle" />
{resolvedImage?.src && <meta name="twitter:image" content={resolvedImage.src} />}
{resolvedImage?.alt && <meta name="twitter:image:alt" content={resolvedImage.alt} />}

<!-- LinkedIn Optimization -->
<meta property="og:profile:first_name" content="Bartłomiej" />
<meta property="og:profile:last_name" content="Miłosz" />

<!-- Article-specific meta for blog posts -->
{pageType === 'article' && (
    <>
        <meta property="article:author" content="Bartłomiej Miłosz" />
        <meta property="article:publisher" content="https://bartlomiej-milosz.github.io" />
        <meta name="twitter:label1" content="Written by" />
        <meta name="twitter:data1" content="Bartłomiej Miłosz" />
        <meta name="twitter:label2" content="Filed under" />
        <meta name="twitter:data2" content="Career Transition, Data Analytics" />
    </>
)}

<!-- Structured Data for Rich Results -->
<script type="application/ld+json" set:html={JSON.stringify(structuredData)} />

<!-- Career Transition & Recruitment SEO -->
<meta name="employment-type" content="Full-time, Contract, Freelance" />
<meta name="job-function" content="Data Analytics, Business Analysis" />
<meta name="industry" content="Technology, Data Science, Business Intelligence" />
<meta name="career-level" content="Junior, Entry-level with Business Experience" />
<meta name="location" content="Warsaw, Poland" />

<!-- Professional Skills Meta -->
<meta name="skills" content="Data Analysis, Python, Excel, Project Management, Client Consulting, Architecture, Business Intelligence" />
<meta name="education" content="PJATK Computer Science, Architecture Masters" />
<meta name="experience-years" content="4+ years client consulting" />

<!-- Rich Results for Career Pages -->
{Astro.url.pathname.includes('/resume') && (
    <script type="application/ld+json" set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "WebPage",
        "name": "Bartłomiej Miłosz - Resume",
        "description": "Professional resume of Bartłomiej Miłosz - Interior Architect transitioning to Data Analytics",
        "url": canonicalURL.toString(),
        "mainEntity": {
            "@type": "Person",
            "name": "Bartłomiej Miłosz",
            "hasOccupation": [
                {
                    "@type": "Occupation",
                    "name": "Interior Architect",
                    "experienceRequirements": "4+ years"
                },
                {
                    "@type": "Occupation", 
                    "name": "Data Analyst",
                    "occupationLocation": {
                        "@type": "City",
                        "name": "Warsaw"
                    }
                }
            ]
        }
    })} />
)}
